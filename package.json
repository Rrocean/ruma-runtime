{
  "name": "ruma-runtime",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ruma-runtime": "./bin/ruma-runtime.mjs"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 4173",
    "build": "vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "cli:list": "node ./bin/ruma-runtime.mjs list",
    "cli:matrix": "node ./bin/ruma-runtime.mjs matrix",
    "cli:random": "node ./bin/ruma-runtime.mjs random",
    "install:runtime:codex": "node ./scripts/install-codex-skill.mjs",
    "install:runtime:claude": "node ./scripts/install-agent-skill.mjs claude ruma-runtime",
    "install:runtime:openclaw": "node ./scripts/install-agent-skill.mjs openclaw ruma-runtime",
    "install:runtime:all": "node ./scripts/install-agent-skill.mjs all ruma-runtime",
    "install:codex": "node ./scripts/install-codex-skill.mjs",
    "install:claude": "node ./scripts/install-agent-skill.mjs claude ruma-runtime",
    "install:openclaw": "node ./scripts/install-agent-skill.mjs openclaw ruma-runtime",
    "install:all": "node ./scripts/install-agent-skill.mjs all ruma-runtime",
    "install:pua:codex": "node ./scripts/install-agent-skill.mjs codex pua",
    "install:pua:claude": "node ./scripts/install-agent-skill.mjs claude pua",
    "install:pua:openclaw": "node ./scripts/install-agent-skill.mjs openclaw pua",
    "install:pua:all": "node ./scripts/install-agent-skill.mjs all pua",
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "check": "npm run build && npm run test",
    "qa:loop": "node ./scripts/qa-loop.mjs",
    "autopilot:once": "powershell -ExecutionPolicy Bypass -File ./scripts/autopilot-once.ps1",
    "autopilot:loop": "powershell -ExecutionPolicy Bypass -File ./scripts/autopilot-loop.ps1",
    "autopilot:register": "powershell -ExecutionPolicy Bypass -File ./scripts/register-autopilot-task.ps1"
  },
  "devDependencies": {
    "@playwright/test": "^1.54.1",
    "vite": "^7.1.7"
  }
}
